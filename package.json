{
    "name": "cypress-interceptor-repo",
    "version": "1.0.0",
    "author": "Martin Tichovsky",
    "description": "",
    "devDependencies": {
        "@babel/core": "7.29.7",
        "@babel/preset-env": "7.29.7",
        "@babel/preset-typescript": "7.29.7",
        "@cypress/code-coverage": "4.0.3",
        "@cypress/webpack-preprocessor": "7.1.1",
        "@eslint/js": "10.0.1",
        "@jsdevtools/coverage-istanbul-loader": "3.0.5",
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/node": "20.19.0",
        "cypress": "15.16.0",
        "eslint": "10.4.1",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-simple-import-sort": "13.0.0",
        "jiti": "2.7.0",
        "prettier": "3.8.3",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "typescript-eslint": "8.60.1"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "license": "MIT",
    "private": true,
    "scripts": {
        "build": "npm run build -w cypress-interceptor",
        "clean": "npm run clean --workspaces --if-present && rimraf  --glob \"**/tsconfig.build.tsbuildinfo\" \"**/tsconfig.*tsbuildinfo\"",
        "clean:node_modules": "rimraf --glob ./**/node_modules",
        "lint": "npm run lint --workspaces",
        "lint:fix": "npm run lint --workspaces -- --fix",
        "server": "npm run start -w cypress-interceptor-server",
        "test": "npm run cy:run -w cypress-interceptor-tests-latest",
        "test:all-browsers": "npm run cy:run --workspaces --if-present && npm run cy:run:chrome --workspaces --if-present && npm run cy:run:edge --workspaces --if-present npm run cy:run:firefox --workspaces --if-present",
        "test:all-cypress": "npm run cy:run --workspaces --if-present",
        "tsc": "npm run tsc --workspaces"
    },
    "workspaces": [
        "packages/*"
    ]
}
